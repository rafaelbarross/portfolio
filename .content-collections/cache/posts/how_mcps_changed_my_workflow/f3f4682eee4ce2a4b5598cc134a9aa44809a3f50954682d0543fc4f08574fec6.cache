"var Component=(()=>{var u=Object.create;var i=Object.defineProperty;var p=Object.getOwnPropertyDescriptor;var g=Object.getOwnPropertyNames;var m=Object.getPrototypeOf,w=Object.prototype.hasOwnProperty;var b=(n,e)=>()=>(e||n((e={exports:{}}).exports,e),e.exports),f=(n,e)=>{for(var o in e)i(n,o,{get:e[o],enumerable:!0})},s=(n,e,o,a)=>{if(e&&typeof e==\"object\"||typeof e==\"function\")for(let r of g(e))!w.call(n,r)&&r!==o&&i(n,r,{get:()=>e[r],enumerable:!(a=p(e,r))||a.enumerable});return n};var y=(n,e,o)=>(o=n!=null?u(m(n)):{},s(e||!n||!n.__esModule?i(o,\"default\",{value:n,enumerable:!0}):o,n)),v=n=>s(i({},\"__esModule\",{value:!0}),n);var l=b((I,h)=>{h.exports=_jsx_runtime});var C={};f(C,{default:()=>c});var t=y(l());function d(n){let e={a:\"a\",code:\"code\",h2:\"h2\",h3:\"h3\",hr:\"hr\",li:\"li\",ol:\"ol\",p:\"p\",pre:\"pre\",strong:\"strong\",ul:\"ul\",...n.components};return(0,t.jsxs)(t.Fragment,{children:[(0,t.jsx)(e.p,{children:\"A few months ago I posted on LinkedIn about MCPs and how they changed the way I work. I got a comment asking me to go deeper, and I promised to write a proper post about it. This is that post.\"}),`\n`,(0,t.jsx)(e.h2,{children:\"What are MCPs?\"}),`\n`,(0,t.jsx)(e.p,{children:\"MCP (Model Context Protocol) is an open protocol created by Anthropic that allows language models to connect to external tools in a standardized way. In practice, you integrate services like Trello, GitHub, Chrome DevTools and Google Calendar directly into your AI assistant \\u2014 and it can read and write to those tools while you have a conversation.\"}),`\n`,(0,t.jsxs)(e.p,{children:[\"With \",(0,t.jsx)(e.strong,{children:\"Claude Code\"}),\", this becomes especially powerful because the agent already lives in your terminal, in the context of your code.\"]}),`\n`,(0,t.jsx)(e.h2,{children:\"The problem MCPs solve\"}),`\n`,(0,t.jsxs)(e.p,{children:[\"The biggest enemy of productivity isn't lack of time. It's \",(0,t.jsx)(e.strong,{children:\"context switching\"}),\".\"]}),`\n`,(0,t.jsx)(e.p,{children:\"You're debugging a bug. You need to create a Trello card. You open the browser, navigate to the board, think about the structure, write the title, describe the problem, add the labels... by the time you get back to the code, you've lost your train of thought.\"}),`\n`,(0,t.jsx)(e.p,{children:\"Multiplied by 10, 20 times a day, that's an absurd amount of wasted focus.\"}),`\n`,(0,t.jsx)(e.p,{children:\"MCPs solve this because the tools come to you, not the other way around.\"}),`\n`,(0,t.jsx)(e.h2,{children:\"The MCPs I use daily\"}),`\n`,(0,t.jsx)(e.h3,{children:\"Trello\"}),`\n`,(0,t.jsx)(e.p,{children:\"Before integrating Trello, creating a card was a manual and tedious process. Now I simply describe what needs to be done:\"}),`\n`,(0,t.jsx)(e.pre,{children:(0,t.jsx)(e.code,{children:`create a trello card: bug on POST /exercise-programs endpoint \\u2014\nreturns 500 when user doesn't have permission. Add to BUG list\nwith BACKEND label.\n`})}),`\n`,(0,t.jsx)(e.p,{children:\"Claude creates the card, already structured, with a formatted description, correct labels and a checklist when it makes sense. What used to take 3-4 minutes now takes 10 seconds.\"}),`\n`,(0,t.jsx)(e.p,{children:\"I also use it to reorganize sprint priorities, move cards between lists and check what's in progress without leaving the terminal.\"}),`\n`,(0,t.jsx)(e.h3,{children:\"GitHub\"}),`\n`,(0,t.jsx)(e.p,{children:\"PR review is one of the most attention-consuming tasks. With the GitHub MCP integrated, I can:\"}),`\n`,(0,t.jsxs)(e.ul,{children:[`\n`,(0,t.jsx)(e.li,{children:\"List open PRs and filter by author or status\"}),`\n`,(0,t.jsx)(e.li,{children:\"Read a full PR diff and ask for an impact analysis\"}),`\n`,(0,t.jsx)(e.li,{children:\"Generate pull request descriptions from commit history\"}),`\n`,(0,t.jsx)(e.li,{children:\"Comment on PRs with agent-generated context\"}),`\n`]}),`\n`,(0,t.jsxs)(e.p,{children:[\"The most useful part day-to-day is \",(0,t.jsx)(e.strong,{children:\"PR description generation\"}),\". Instead of writing from scratch, the agent reads the commits, understands what was done and generates a structured description \\u2014 summary, technical changes, how to test.\"]}),`\n`,(0,t.jsx)(e.h3,{children:\"Chrome DevTools\"}),`\n`,(0,t.jsx)(e.p,{children:\"This is the MCP that surprises people the most when they see it for the first time.\"}),`\n`,(0,t.jsx)(e.p,{children:\"The agent can control the browser: navigate to a URL, inspect elements, read console errors, analyze network requests and even take screenshots \\u2014 all while you're discussing the problem.\"}),`\n`,(0,t.jsx)(e.p,{children:\"A real example: I was debugging a layout issue that only appeared on a specific screen. Instead of switching back and forth between terminal and DevTools, I described the problem, the agent opened the browser, navigated to the page, inspected the problematic element and showed me exactly which CSS rule was causing the conflict.\"}),`\n`,(0,t.jsx)(e.pre,{children:(0,t.jsx)(e.code,{children:`navigate to localhost:3000/dashboard and check if there are any console errors\n`})}),`\n`,(0,t.jsx)(e.h3,{children:\"Context7\"}),`\n`,(0,t.jsx)(e.p,{children:\"Outdated documentation is a classic LLM problem. Context7 solves this by fetching the latest docs for libs in real time.\"}),`\n`,(0,t.jsx)(e.p,{children:\"Instead of the agent answering based on what it learned during training (which may be outdated), it fetches the current documentation for the library and responds based on that.\"}),`\n`,(0,t.jsx)(e.p,{children:\"I use it constantly when working with fast-moving libs \\u2014 Next.js, Tailwind, Zod, TanStack Query. The difference in response quality is noticeable.\"}),`\n`,(0,t.jsx)(e.pre,{children:(0,t.jsx)(e.code,{children:`how do I configure the i18n middleware in next-intl v4?\n`})}),`\n`,(0,t.jsx)(e.p,{children:\"The agent resolves the library ID, fetches the docs for the correct version and responds based on what's up to date today.\"}),`\n`,(0,t.jsx)(e.h3,{children:\"Google Calendar\"}),`\n`,(0,t.jsx)(e.p,{children:\"Smaller visual impact, but very useful during planning. I check availability, see meetings for the day and plan focus blocks without opening Google Calendar.\"}),`\n`,(0,t.jsx)(e.pre,{children:(0,t.jsx)(e.code,{children:`what do I have tomorrow morning? I want to block 2h for focused work\n`})}),`\n`,(0,t.jsx)(e.h2,{children:\"What really changed\"}),`\n`,(0,t.jsxs)(e.p,{children:[\"The change isn't just speed. It's \",(0,t.jsx)(e.strong,{children:\"focus\"}),\".\"]}),`\n`,(0,t.jsx)(e.p,{children:\"With MCPs, I can keep my thinking on the problem while the tools work around me. The bug's logic, the feature's architecture, the task's context \\u2014 all of it stays intact because I didn't have to leave the terminal to make things happen.\"}),`\n`,(0,t.jsx)(e.p,{children:\"Less context switching, less friction, more delivery.\"}),`\n`,(0,t.jsx)(e.h2,{children:\"How to get started\"}),`\n`,(0,t.jsxs)(e.p,{children:[\"If you use \",(0,t.jsx)(e.strong,{children:\"Claude Code\"}),\", configuring MCPs is straightforward:\"]}),`\n`,(0,t.jsxs)(e.ol,{children:[`\n`,(0,t.jsx)(e.li,{children:\"Open Claude Code settings\"}),`\n`,(0,t.jsxs)(e.li,{children:[\"Go to \",(0,t.jsx)(e.strong,{children:\"Extensions > MCP Servers\"})]}),`\n`,(0,t.jsx)(e.li,{children:\"Add the servers you want to use\"}),`\n`]}),`\n`,(0,t.jsxs)(e.p,{children:[\"Most popular MCPs have configuration docs on the \",(0,t.jsx)(e.a,{href:\"https://github.com/modelcontextprotocol/servers\",children:\"MCP Hub\"}),\". The process is basically add the server, authenticate and start using.\"]}),`\n`,(0,t.jsx)(e.p,{children:\"Start with one or two MCPs from the tools you already use. The value becomes evident quickly.\"}),`\n`,(0,t.jsx)(e.hr,{}),`\n`,(0,t.jsx)(e.p,{children:\"If you have questions about a specific MCP or how to integrate it into your workflow, feel free to reach out \\u2014 I promised this post to Sandro and it deserved to be detailed hehe.\"})]})}function c(n={}){let{wrapper:e}=n.components||{};return e?(0,t.jsx)(e,{...n,children:(0,t.jsx)(d,{...n})}):d(n)}return v(C);})();\n;return Component;"