"var Component=(()=>{var m=Object.create;var i=Object.defineProperty;var p=Object.getOwnPropertyDescriptor;var h=Object.getOwnPropertyNames;var b=Object.getPrototypeOf,g=Object.prototype.hasOwnProperty;var v=(a,e)=>()=>(e||a((e={exports:{}}).exports,e),e.exports),f=(a,e)=>{for(var r in e)i(a,r,{get:e[r],enumerable:!0})},d=(a,e,r,s)=>{if(e&&typeof e==\"object\"||typeof e==\"function\")for(let n of h(e))!g.call(a,n)&&n!==r&&i(a,n,{get:()=>e[n],enumerable:!(s=p(e,n))||s.enumerable});return a};var C=(a,e,r)=>(r=a!=null?m(b(a)):{},d(e||!a||!a.__esModule?i(r,\"default\",{value:a,enumerable:!0}):r,a)),q=a=>d(i({},\"__esModule\",{value:!0}),a);var c=v((P,t)=>{t.exports=_jsx_runtime});var x={};f(x,{default:()=>u});var o=C(c());function l(a){let e={a:\"a\",code:\"code\",h2:\"h2\",h3:\"h3\",hr:\"hr\",li:\"li\",ol:\"ol\",p:\"p\",pre:\"pre\",strong:\"strong\",ul:\"ul\",...a.components};return(0,o.jsxs)(o.Fragment,{children:[(0,o.jsx)(e.p,{children:\"Alguns meses atr\\xE1s eu fiz um post no LinkedIn falando sobre MCPs e como eles mudaram a forma como eu trabalho. Recebi um coment\\xE1rio pedindo para detalhar mais, e prometi criar um material bacana sobre isso. Esse \\xE9 esse material.\"}),`\n`,(0,o.jsx)(e.h2,{children:\"O que s\\xE3o MCPs?\"}),`\n`,(0,o.jsx)(e.p,{children:\"MCP (Model Context Protocol) \\xE9 um protocolo aberto criado pela Anthropic que permite que modelos de linguagem se conectem a ferramentas externas de forma padronizada. Na pr\\xE1tica, voc\\xEA integra servi\\xE7os como Trello, GitHub, Chrome DevTools e Google Calendar diretamente no seu assistente de IA \\u2014 e ele pode ler e escrever nessas ferramentas enquanto voc\\xEA conversa.\"}),`\n`,(0,o.jsxs)(e.p,{children:[\"Com o \",(0,o.jsx)(e.strong,{children:\"Claude Code\"}),\", isso fica especialmente poderoso porque o agente j\\xE1 vive no seu terminal, no contexto do seu c\\xF3digo.\"]}),`\n`,(0,o.jsx)(e.h2,{children:\"O problema que os MCPs resolvem\"}),`\n`,(0,o.jsxs)(e.p,{children:[\"O maior inimigo da produtividade n\\xE3o \\xE9 falta de tempo. \\xC9 a \",(0,o.jsx)(e.strong,{children:\"troca de contexto\"}),\".\"]}),`\n`,(0,o.jsx)(e.p,{children:\"Voc\\xEA est\\xE1 debugando um bug. Precisa criar um card no Trello. Abre o browser, navega at\\xE9 o board, pensa na estrutura, escreve o t\\xEDtulo, detalha o problema, adiciona as labels... quando volta ao c\\xF3digo, perdeu o fio do racioc\\xEDnio.\"}),`\n`,(0,o.jsx)(e.p,{children:\"Multiplicado por 10, 20 vezes por dia, \\xE9 uma quantidade absurda de foco desperdi\\xE7ado.\"}),`\n`,(0,o.jsx)(e.p,{children:\"MCPs resolvem isso porque as ferramentas v\\xEAm at\\xE9 voc\\xEA, n\\xE3o o contr\\xE1rio.\"}),`\n`,(0,o.jsx)(e.h2,{children:\"Os MCPs que uso no meu dia a dia\"}),`\n`,(0,o.jsx)(e.h3,{children:\"Trello\"}),`\n`,(0,o.jsx)(e.p,{children:\"Antes de integrar o Trello, criar um card era um processo manual e chato. Agora eu simplesmente descrevo o que precisa ser feito:\"}),`\n`,(0,o.jsx)(e.pre,{children:(0,o.jsx)(e.code,{children:`cria um card no trello: bug no endpoint POST /exercise-programs \\u2014\nretorna 500 quando o usu\\xE1rio n\\xE3o tem permiss\\xE3o. Adiciona na lista BUG\ncom label BACKEND.\n`})}),`\n`,(0,o.jsx)(e.p,{children:\"O Claude cria o card, j\\xE1 estruturado, com a descri\\xE7\\xE3o formatada, labels corretas e checklist quando faz sentido. O que levava 3-4 minutos agora leva 10 segundos.\"}),`\n`,(0,o.jsx)(e.p,{children:\"Uso tamb\\xE9m para reorganizar prioridades durante o planejamento de sprint, mover cards entre listas e consultar o que est\\xE1 em andamento sem sair do terminal.\"}),`\n`,(0,o.jsx)(e.h3,{children:\"GitHub\"}),`\n`,(0,o.jsx)(e.p,{children:\"Revis\\xE3o de PR \\xE9 uma das tarefas que mais consomem aten\\xE7\\xE3o. Com o MCP do GitHub integrado, consigo:\"}),`\n`,(0,o.jsxs)(e.ul,{children:[`\n`,(0,o.jsx)(e.li,{children:\"Listar PRs abertos e filtrar por autor ou status\"}),`\n`,(0,o.jsx)(e.li,{children:\"Ler o diff completo de um PR e pedir uma an\\xE1lise de impacto\"}),`\n`,(0,o.jsx)(e.li,{children:\"Gerar descri\\xE7\\xF5es de pull request a partir do hist\\xF3rico de commits\"}),`\n`,(0,o.jsx)(e.li,{children:\"Comentar em PRs com contexto gerado pelo agente\"}),`\n`]}),`\n`,(0,o.jsxs)(e.p,{children:[\"A parte mais \\xFAtil no dia a dia \\xE9 a \",(0,o.jsx)(e.strong,{children:\"gera\\xE7\\xE3o de descri\\xE7\\xF5es de PR\"}),\". Ao inv\\xE9s de escrever do zero, o agente l\\xEA os commits, entende o que foi feito e gera uma descri\\xE7\\xE3o estruturada \\u2014 sum\\xE1rio, mudan\\xE7as t\\xE9cnicas, como testar.\"]}),`\n`,(0,o.jsx)(e.h3,{children:\"Chrome DevTools\"}),`\n`,(0,o.jsx)(e.p,{children:\"Esse \\xE9 o MCP que mais surpreende quem v\\xEA pela primeira vez.\"}),`\n`,(0,o.jsx)(e.p,{children:\"O agente consegue controlar o browser: navegar para uma URL, inspecionar elementos, ler erros do console, analisar requests de rede e at\\xE9 tirar screenshots \\u2014 tudo enquanto voc\\xEA conversa sobre o problema.\"}),`\n`,(0,o.jsx)(e.p,{children:\"Um exemplo real: estava debugando um problema de layout que s\\xF3 aparecia em tela espec\\xEDfica. Ao inv\\xE9s de ficar alternando entre terminal e DevTools, descrevi o problema, o agente abriu o browser, navegou at\\xE9 a p\\xE1gina, inspecionou o elemento problem\\xE1tico e me mostrou exatamente qual regra CSS estava causando o conflito.\"}),`\n`,(0,o.jsx)(e.pre,{children:(0,o.jsx)(e.code,{children:`navega at\\xE9 localhost:3000/dashboard e verifica se h\\xE1 erros no console\n`})}),`\n`,(0,o.jsx)(e.h3,{children:\"Context7\"}),`\n`,(0,o.jsx)(e.p,{children:\"Documenta\\xE7\\xE3o desatualizada \\xE9 um problema cl\\xE1ssico de LLMs. O Context7 resolve isso buscando a documenta\\xE7\\xE3o mais recente das libs em tempo real.\"}),`\n`,(0,o.jsx)(e.p,{children:\"Ao inv\\xE9s de o agente responder com base no que aprendeu no treinamento (que pode estar desatualizado), ele busca a documenta\\xE7\\xE3o atual da biblioteca e responde com base nela.\"}),`\n`,(0,o.jsx)(e.p,{children:\"Uso constantemente quando estou trabalhando com libs que evoluem r\\xE1pido \\u2014 Next.js, Tailwind, Zod, TanStack Query. A diferen\\xE7a na qualidade das respostas \\xE9 not\\xE1vel.\"}),`\n`,(0,o.jsx)(e.pre,{children:(0,o.jsx)(e.code,{children:`como configuro o middleware de i18n no next-intl v4?\n`})}),`\n`,(0,o.jsx)(e.p,{children:\"O agente resolve a library ID, busca a documenta\\xE7\\xE3o da vers\\xE3o correta e responde com base no que est\\xE1 atualizado hoje.\"}),`\n`,(0,o.jsx)(e.h3,{children:\"Google Calendar\"}),`\n`,(0,o.jsx)(e.p,{children:\"Menor impacto visual, mas muito \\xFAtil durante planejamento. Consulto disponibilidade, vejo reuni\\xF5es do dia e planejo blocos de trabalho sem precisar abrir o Google Calendar.\"}),`\n`,(0,o.jsx)(e.pre,{children:(0,o.jsx)(e.code,{children:`o que tenho amanh\\xE3 de manh\\xE3? quero bloquear 2h para trabalho focado\n`})}),`\n`,(0,o.jsx)(e.h2,{children:\"O que realmente mudou\"}),`\n`,(0,o.jsxs)(e.p,{children:[\"A mudan\\xE7a n\\xE3o \\xE9 s\\xF3 velocidade. \\xC9 \",(0,o.jsx)(e.strong,{children:\"foco\"}),\".\"]}),`\n`,(0,o.jsx)(e.p,{children:\"Com MCPs, consigo manter o racioc\\xEDnio no problema enquanto as ferramentas trabalham ao redor. A l\\xF3gica do bug, a arquitetura da feature, o contexto da tarefa \\u2014 tudo isso fica intacto porque eu n\\xE3o precisei sair do terminal para fazer as coisas acontecerem.\"}),`\n`,(0,o.jsx)(e.p,{children:\"Menos altern\\xE2ncia de contexto, menos fric\\xE7\\xE3o, mais entrega.\"}),`\n`,(0,o.jsx)(e.h2,{children:\"Como come\\xE7ar\"}),`\n`,(0,o.jsxs)(e.p,{children:[\"Se voc\\xEA usa o \",(0,o.jsx)(e.strong,{children:\"Claude Code\"}),\", configurar MCPs \\xE9 direto:\"]}),`\n`,(0,o.jsxs)(e.ol,{children:[`\n`,(0,o.jsx)(e.li,{children:\"Abra as configura\\xE7\\xF5es do Claude Code\"}),`\n`,(0,o.jsxs)(e.li,{children:[\"V\\xE1 em \",(0,o.jsx)(e.strong,{children:\"Extensions > MCP Servers\"})]}),`\n`,(0,o.jsx)(e.li,{children:\"Adicione os servidores que quer usar\"}),`\n`]}),`\n`,(0,